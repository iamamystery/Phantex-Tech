# Phantex Tech backend — environment variables
# Copy to .env for local dev (optional) or set these in Render for production.
# .env is gitignored; this example is safe to commit.

# --- Core (required in production) ----------------------------------------
SECRET_KEY=change-me-to-a-long-random-50+-char-value
DJANGO_DEBUG=False
# Comma-separated, no scheme. Use your Render service hostname.
ALLOWED_HOSTS=phantex-backend.onrender.com

# --- Database -------------------------------------------------------------
# When unset, the app falls back to local SQLite (db.sqlite3) for development.
# On Render this is provided automatically by the managed Postgres database.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Cross-origin / CSRF (required so the Vercel frontend can call the API) -
# Comma-separated, WITH scheme.
CORS_ALLOWED_ORIGINS=https://frontend-murex-rho-51.vercel.app,https://phantextech.com
CSRF_TRUSTED_ORIGINS=https://phantex-backend.onrender.com,https://frontend-murex-rho-51.vercel.app
# Optional: regex allowlist for Vercel preview deployments.
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$

# --- Optional -------------------------------------------------------------
# Point uploaded media at a Render persistent disk mount (otherwise ephemeral).
# MEDIA_ROOT=/var/data/media
# Set to False only if you must disable the HTTP->HTTPS redirect.
# SECURE_SSL_REDIRECT=True

# --- Optional first-deploy admin user (consumed by build.sh) --------------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@phantextech.com
# DJANGO_SUPERUSER_PASSWORD=use-a-strong-password
